{
  "framework": "nextjs",
  "builds": [{ "src": "package.json", "use": "@vercel/next" }],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "drdacademyofficial.com" }],
      "destination": "https://www.drdacademyofficial.com/$1",
      "permanent": true
    }
  ]
}
